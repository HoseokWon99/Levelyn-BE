# Server
PORT=3000
HOST=0.0.0.0

# Database (MySQL)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=levelyn

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800

# Kakao OAuth2
OAUTH2_KAKAO_TOKEN_URL=https://kauth.kakao.com/oauth/token
OAUTH2_KAKAO_USER_INFO_URL=https://kapi.kakao.com/v2/user/me
OAUTH2_KAKAO_CLIENT_ID=
OAUTH2_KAKAO_CLIENT_SECRET=
OAUTH2_KAKAO_CALLBACK_URL=

# Notifications (SSE)
# How often the server polls Redis for new notifications (ms)
NOTIFICATION_BLOCK_TIMEOUT=500
# Heartbeat interval sent to SSE clients (ms)
SSE_HEARTBEAT_PERIOD=30000
# Maximum number of messages to keep per user stream
STREAM_MAX_LENGTH=500

# Event Store
# Maximum number of events to keep in the event store (~30 days at 1500/day)
EVENT_STORE_MAX_LENGTH=50000
# Maximum number of commands to keep in the command store (~30 days at 1500/day)
COMMAND_STORE_MAX_LENGTH=50000

# Random
RANDOM_SEED=
